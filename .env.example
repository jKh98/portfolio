# Firebase Configuration
# Copy this file to .env and fill in your Firebase project values.
# Get these from Firebase Console → Project Settings → General → Your apps → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase App Check (reCAPTCHA Enterprise)
# Get your site key from Google Cloud Console → reCAPTCHA Enterprise.
# See: https://firebase.google.com/docs/app-check/web/recaptcha-enterprise-provider
VITE_RECAPTCHA_SITE_KEY=

# Set to "true" to enable App Check debug token in development
VITE_APPCHECK_DEBUG=true
